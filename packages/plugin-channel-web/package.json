{
  "name": "@moxxy/plugin-channel-web",
  "version": "0.29.0",
  "description": "Web surface channel for moxxy: serves a browser app that renders agent-authored view-spec UIs over a WebSocket, and routes form/button actions back into the session as new turns.",
  "keywords": [
    "moxxy",
    "agent",
    "channel",
    "web",
    "surface"
  ],
  "homepage": "https://moxxy.ai",
  "bugs": {
    "url": "https://github.com/moxxy-ai/moxxy/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/moxxy-ai/moxxy.git",
    "directory": "packages/plugin-channel-web"
  },
  "author": "Michal Makowski <michal.makowski97@gmail.com>",
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json && node scripts/build-web.mjs",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "clean": "rm -rf dist .turbo"
  },
  "moxxy": {
    "plugin": {
      "entry": "./dist/index.js",
      "kind": "channel"
    }
  },
  "dependencies": {
    "@moxxy/plugin-tunnel-proxy": "workspace:*",
    "@moxxy/sdk": "workspace:*",
    "ws": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@moxxy/core": "workspace:*",
    "@moxxy/tsconfig": "workspace:*",
    "@moxxy/vitest-preset": "workspace:*",
    "@types/node": "catalog:",
    "@types/react": "catalog:",
    "@types/react-dom": "catalog:",
    "@types/ws": "catalog:",
    "esbuild": "catalog:",
    "react": "catalog:",
    "react-dom": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  }
}
