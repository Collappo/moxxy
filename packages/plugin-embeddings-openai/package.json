{
  "name": "@moxxy/plugin-embeddings-openai",
  "version": "0.0.0",
  "description": "OpenAI EmbeddingProvider for moxxy. Wraps text-embedding-3-small (1536d) by default; pluggable into MemoryStore for semantic recall.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": ["dist", "src"],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "clean": "rm -rf dist .turbo"
  },
  "moxxy": { "plugin": { "entry": "./dist/index.js", "kind": "tools" } },
  "dependencies": {
    "@moxxy/sdk": "workspace:*",
    "openai": "^4.80.0"
  },
  "devDependencies": {
    "@moxxy/tsconfig": "workspace:*",
    "@moxxy/vitest-preset": "workspace:*",
    "@types/node": "^22.10.0",
    "typescript": "^5.7.3",
    "vitest": "^2.1.8"
  }
}
