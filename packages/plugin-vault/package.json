{
  "name": "@moxxy/plugin-vault",
  "version": "0.0.0",
  "description": "Encrypted secret storage for moxxy. AES-256-GCM at rest. Master key from OS keychain (keytar) or passphrase fallback.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": ["dist", "src"],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "clean": "rm -rf dist .turbo"
  },
  "moxxy": { "plugin": { "entry": "./dist/index.js", "kind": "tools" } },
  "dependencies": {
    "@moxxy/sdk": "workspace:*",
    "zod": "^3.24.0"
  },
  "optionalDependencies": {
    "keytar": "^7.9.0"
  },
  "devDependencies": {
    "@moxxy/tsconfig": "workspace:*",
    "@moxxy/vitest-preset": "workspace:*",
    "@types/node": "^22.10.0",
    "typescript": "^5.7.3",
    "vitest": "^2.1.8"
  }
}
